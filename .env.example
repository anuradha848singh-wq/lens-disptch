# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# News API Configuration (Choose one for auto-fetching real news)
# Get a free key at https://gnews.io/
NEWS_API_KEY=your_gnews_api_key_here

# OR get a free key at https://newsapi.org/ (Only for local development)
NEWSAPI_KEY=your_newsapi_org_key_here

# Server Configuration
PORT=5000
NODE_ENV=development
