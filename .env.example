# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ─── Redis (required for BullMQ job queue) ──────────────
REDIS_URL=redis://localhost:6379

# ─── News API Keys (at least one required for auto-fetching) ──
# Get a free key at https://gnews.io/
NEWS_API_KEY=your_gnews_api_key_here

# OR get a free key at https://newsapi.org/ (Only for local development)
NEWSAPI_KEY=your_newsapi_org_key_here

# ─── Embedding Service (for semantic clustering) ────────
EMBEDDING_SERVICE_URL=http://localhost:8001

# ─── Server Configuration ──────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS (production: comma-separated allowed origins) ─
# CORS_ORIGIN=https://your-frontend.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-staging.vercel.app

# ─── Docker Compose Passwords (used in docker-compose.yml) ─
# POSTGRES_PASSWORD=devpassword
# REDIS_PASSWORD=redisdevpass
